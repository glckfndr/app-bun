{
  "name": "app-bun",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "server": "bun packages/server/index.ts",
    "dev": "bun --watch packages/server/index.ts",
    "client": "bun --cwd packages/client dev",
    "client:build": "bun --cwd packages/client build",
    "client:preview": "bun --cwd packages/client preview"
  },
  "workspaces": [
    "packages/*"
  ]
}
